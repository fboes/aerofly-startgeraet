{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "sourceMap": false,
    "newLine": "LF",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declarationMap": true,
    "declaration": true,
    "declarationDir": "./types",
    "resolveJsonModule": true,
    "types": ["node"]
  }
}
