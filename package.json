{
  "name": "@fboes/aerofly-startgeraet",
  "version": "1.3.0",
  "description": "The Auxiliary Power Unit for Aerofly Flight Simulator 4: Improving the main menu with meaningful units and import functionality for weather and flight plans.",
  "main": "./dist/cli/index.js",
  "scripts": {
    "test": "node --test 'dist/**/*.test.js'",
    "test:coverage": "node --test --experimental-test-coverage 'dist/**/*.test.js'",
    "test:watch": "node --test --watch 'dist/**/*.test.js'",
    "test:mcp": "npx @modelcontextprotocol/inspector node ./dist/mcp/index.js",
    "start": "node ./dist/cli/index.js",
    "start:mcp": "node ./dist/mcp/index.js",
    "prettier": "npx prettier --cache --write .",
    "eslint": "npx eslint src/**/*.ts --fix",
    "tsc": "npx tsc --build",
    "tsc-watch": "npx tsc --watch",
    "fix-access-rights": "find src -type d -name \"@eaDir\" -prune -o -exec chmod 0755 {} \\; && find src -type f -exec chmod 0644 {} \\; && find src -type f -name \"index.ts\" -exec chmod 0755 {} \\;",
    "build": "npm run eslint && npm run fix-access-rights && npm run tsc && npm run prettier",
    "build:mcp": "npx @anthropic-ai/mcpb pack"
  },
  "keywords": [
    "aerofly",
    "aerofly-fs4",
    "flightplan",
    "metar",
    "simbrief"
  ],
  "bin": {
    "aerofly-startgeraet": "./dist/cli/index.js"
  },
  "author": "Frank Boës <info@fboes.org> (https://3960.org/)",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "types": "./types/index.d.ts",
  "dependencies": {
    "@fboes/aerofly-custom-missions": "^1.6.0",
    "@fboes/aerofly-data": "^1.5.0",
    "@fboes/geojson": "^2.0.0",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "aewx-metar-parser": "^2.0.1",
    "conf": "^15.1.0",
    "zod": "^4.3.6"
  }
}
