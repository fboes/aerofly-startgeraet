    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "types": "./types/index.d.ts",
  "dependencies": {
    "@fboes/aerofly-custom-missions": "^1.6.0",
